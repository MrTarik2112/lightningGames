{
  "name": "lightning-games",
  "version": "2.2.7",
  "description": "⚡ Lightning Games - Quick game launcher that lives in your system tray",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "dist": "node scripts/build.js",
    "build": "node scripts/build.js",
    "build:win": "npx electron-builder --win portable",
    "build:linux": "wsl bash -c \"cd /mnt/c/Users/tarik/Documents/lightningGames && npx electron-builder --linux AppImage\"",
    "bun:install": "bun install",
    "bun:start": "bun run start",
    "bun:dev": "bun run dev",
    "bun:dist": "bun run dist",
    "ui": "wsl -d Ubuntu bash -c \"export DISPLAY=:0 && cd /mnt/c/Users/tarik/OneDrive/Belgeler/lightninggames/build-ui/build && ./lightning-build-ui\"",
    "ui:native": "build-ui\\build_win\\lightning-build-ui.exe",
    "ui:compile-win": "wsl bash -c \"cd /mnt/c/Users/tarik/OneDrive/Belgeler/lightninggames/build-ui && bash setup-win.sh\"",
    "tailwind": "tailwindcss -i ./styles/tailwind.css -o ./styles/tailwind-output.css --watch"
  },
  "author": "Tarik",
  "license": "MIT",
  "devDependencies": {
    "autoprefixer": "^10.4.16",
    "canvas": "^3.2.1",
    "electron": "28.0.0",
    "electron-builder": "^23.6.0",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.1"
  },
  "build": {
    "appId": "com.tarik.lightninggames",
    "productName": "Lightning Games",
    "asar": true,
    "asarUnpack": [
      "**/*.node"
    ],
    "compression": "store",
    "win": {
      "target": "portable",
      "icon": "assets/icon.ico"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png",
      "category": "Game",
      "maintainer": "Tarik"
    },
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!**/node_modules/**",
      "!**/dist/**",
      "!**/BuildLogs/**",
      "!**/.git/**",
      "!**/.crush/**",
      "!**/Docs/**",
      "!**/scripts/**",
      "!**/temp_*/**",
      "!**/*.md",
      "!.gitignore",
      "!.gitattributes"
    ],
    "extraMetadata": {
      "main": "main.js"
    }
  }
}
