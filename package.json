{
  "name": "lightning-games",
  "version": "2.1.6",
  "description": "⚡ Lightning Games - Quick game launcher that lives in your system tray",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "dist": "node scripts/build.js"
  },
  "author": "Tarik",
  "license": "MIT",
  "devDependencies": {
    "canvas": "^3.2.1",
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3",
    "png-to-ico": "^3.0.1"
  },
  "build": {
    "appId": "com.tarik.lightninggames",
    "productName": "Lightning Games",
    "asar": true,
    "compression": "store",
    "win": {
      "target": "portable",
      "icon": "assets/icon.ico"
    },
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!dist/*",
      "!BuildLogs/*"
    ]
  }
}
