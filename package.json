{
  "name": "lightning-games",
  "version": "2.2.7",
  "description": "⚡ Lightning Games - Quick game launcher that lives in your system tray",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "dist": "node scripts/build.js",
    "build": "node scripts/build.js",
    "build:win": "npx electron-builder --win portable",
    "build:linux": "wsl bash -c \"cd /mnt/c/Users/tarik/Documents/lightningGames && npx electron-builder --linux AppImage\"",
    "bun:install": "bun install",
    "bun:start": "bun run start",
    "bun:dev": "bun run dev",
    "bun:dist": "bun run dist",
    "tailwind": "tailwindcss -i ./styles/tailwind.css -o ./styles/tailwind-output.css --watch"
  },
  "author": "Tarik",
  "license": "MIT",
  "devDependencies": {
    "canvas": "^3.2.1",
    "electron": "28.0.0",
    "electron-builder": "24.13.3",
    "png-to-ico": "^3.0.1",
    "tailwindcss": "^3.4.1",
    "postcss": "^8.4.32",
    "autoprefixer": "^10.4.16"
  },
  "build": {
    "appId": "com.tarik.lightninggames",
    "productName": "Lightning Games",
    "asar": true,
    "asarUnpack": [
      "**/*.node"
    ],
    "compression": "store",
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "certificateFile": null,
      "certificatePassword": null,
      "signingHashAlgorithms": [
        "sha256"
      ],
      "sign": null
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png",
      "category": "Game",
      "maintainer": "Tarik"
    },
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!**/node_modules/**",
      "!**/dist/**",
      "!**/BuildLogs/**",
      "!**/.git/**",
      "!**/.crush/**",
      "!**/Docs/**",
      "!**/scripts/**",
      "!**/temp_*/**",
      "!**/*.md",
      "!.gitignore",
      "!.gitattributes"
    ],
    "extraMetadata": {
      "main": "main.js"
    }
  }
}
