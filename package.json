{
  "name": "lightning-games",
  "version": "2.1.7",
  "description": "⚡ Lightning Games - Quick game launcher that lives in your system tray",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "dist": "node scripts/build.js",
    "build:win": "electron-builder --win portable",
    "build:linux": "electron-builder --linux AppImage",
    "build:all": "electron-builder --win portable --linux AppImage",
    "bun:install": "bun install",
    "bun:start": "bun run start",
    "bun:dev": "bun run dev",
    "bun:dist": "bun run dist"
  },
  "author": "Tarik",
  "license": "MIT",
  "devDependencies": {
    "canvas": "^3.2.1",
    "electron": "28.0.0",
    "electron-builder": "24.13.3",
    "png-to-ico": "^3.0.1"
  },
  "build": {
    "appId": "com.tarik.lightninggames",
    "productName": "Lightning Games",
    "asar": true,
    "asarUnpack": [
      "**/*.node"
    ],
    "compression": "store",
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "certificateFile": null,
      "certificatePassword": null,
      "signingHashAlgorithms": [
        "sha256"
      ],
      "sign": null
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png",
      "category": "Game",
      "maintainer": "Tarik"
    },
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "renderer/**/*",
      "games/**/*",
      "styles/**/*",
      "assets/**/*",
      "package.json",
      "!**/*.map",
      "!**/node_modules/*/{CHANGELOG.md,README.md,README,readme.md,readme,LICENSE,license,LICENSE.txt,license.txt}",
      "!**/node_modules/*/test",
      "!**/node_modules/*/tests",
      "!**/node_modules/*/.bin",
      "!**/node_modules/*/.github",
      "!**/node_modules/*/.gitignore",
      "!**/node_modules/*/.npmignore",
      "!**/node_modules/*/.eslintignore",
      "!**/node_modules/*/.editorconfig",
      "!**/node_modules/*/.travis.yml",
      "!**/node_modules/*/.jshintrc",
      "!**/node_modules/*/.babelrc",
      "!**/node_modules/*/.prettierrc",
      "!**/node_modules/*/.eslintrc*",
      "!**/node_modules/*/tsconfig.json",
      "!**/node_modules/*/tslint.json",
      "!**/node_modules/*/jest.config.js",
      "!**/node_modules/*/webpack.config.js",
      "!**/node_modules/*/gulpfile.js",
      "!**/node_modules/*/Gruntfile.js",
      "!**/node_modules/*/rollup.config.js",
      "!**/node_modules/*/package-lock.json",
      "!**/node_modules/*/yarn.lock",
      "!**/node_modules/*/pnpm-lock.yaml",
      "!**/node_modules/*/.git",
      "!**/node_modules/*/.svn",
      "!**/node_modules/*/.hg",
      "!**/node_modules/*/.DS_Store",
      "!**/node_modules/*/.nyc_output",
      "!**/node_modules/*/.cache",
      "!**/node_modules/*/.vscode-test",
      "!**/node_modules/*/.vscode",
      "!**/node_modules/*/.idea",
      "!**/node_modules/*/dist",
      "!**/node_modules/*/build",
      "!**/node_modules/*/coverage",
      "!**/node_modules/*/docs",
      "!**/node_modules/*/examples",
      "!**/node_modules/*/demo",
      "!**/node_modules/*/sample",
      "!**/node_modules/*/samples",
      "!**/node_modules/*/src",
      "!**/node_modules/*/lib",
      "!**/node_modules/*/scripts",
      "!**/node_modules/*/spec",
      "!**/node_modules/*/benchmark",
      "!**/node_modules/*/benchmarks",
      "!**/node_modules/*/perf",
      "!**/node_modules/*/performance",
      "!**/node_modules/*/man",
      "!**/node_modules/*/doc",
      "!**/node_modules/*/docs",
      "!**/node_modules/*/website",
      "!**/node_modules/*/www",
      "!**/node_modules/*/html",
      "!**/node_modules/*/media",
      "!**/node_modules/*/images",
      "!**/node_modules/*/svg",
      "!**/node_modules/*/png",
      "!**/node_modules/*/jpg",
      "!**/node_modules/*/jpeg",
      "!**/node_modules/*/gif",
      "!**/node_modules/*/webp",
      "!**/node_modules/*/ico",
      "!**/node_modules/*/font",
      "!**/node_modules/*/fonts",
      "!**/node_modules/*/ttf",
      "!**/node_modules/*/otf",
      "!**/node_modules/*/woff",
      "!**/node_modules/*/woff2",
      "!**/node_modules/*/eot",
      "!**/node_modules/*/svg",
      "!**/node_modules/*/mp3",
      "!**/node_modules/*/mp4",
      "!**/node_modules/*/wav",
      "!**/node_modules/*/webm",
      "!**/node_modules/*/ogg",
      "!**/node_modules/*/flac",
      "!**/node_modules/*/aac",
      "!**/node_modules/*/m4a",
      "!**/node_modules/*/wma",
      "!**/node_modules/*/zip",
      "!**/node_modules/*/tar",
      "!**/node_modules/*/gz",
      "!**/node_modules/*/rar",
      "!**/node_modules/*/7z",
      "!**/node_modules/*/bz2",
      "!**/node_modules/*/xz",
      "!**/node_modules/*/iso",
      "!**/node_modules/*/dmg",
      "!**/node_modules/*/exe",
      "!**/node_modules/*/msi",
      "!**/node_modules/*/deb",
      "!**/node_modules/*/rpm",
      "!**/node_modules/*/apk",
      "!**/node_modules/*/app",
      "!**/node_modules/*/ipa",
      "!**/node_modules/*/aab"
    ],
    "extraMetadata": {
      "main": "main.js"
    }
  }
}
